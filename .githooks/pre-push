#!/bin/bash
# Leggo pre-push hook — runs PHPUnit before pushing.
# PHPUnit precisa do driver pdo_mysql + MySQL, que vivem no container Docker
# (o PHP do host normalmente não tem o driver). Por isso rodamos a suíte DENTRO
# do container. Se o container não estiver rodando, o hook avisa e PULA (não
# bloqueia o push) — rode os testes manualmente antes de subir nesse caso.
# Setup: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

CONTAINER=leggo

if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$CONTAINER"; then
    echo -e "${YELLOW}Container '$CONTAINER' não está rodando — PHPUnit pulado no pre-push.${NC}"
    echo -e "${YELLOW}Suba o ambiente e rode a suíte antes de subir mudanças:${NC}"
    echo -e "${YELLOW}  docker compose -f docker/docker-compose.yml up -d${NC}"
    echo -e "${YELLOW}  docker exec $CONTAINER php /var/www/leggo/site/app/inc/lib/vendor/bin/phpunit -c /var/www/leggo/site/phpunit.xml${NC}"
    exit 0
fi

PHPUNIT_FAILED=false

for DIR in manager site; do
    if [ -f "$DIR/phpunit.xml" ]; then
        echo "→ PHPUnit ($DIR)..."
        if docker exec "$CONTAINER" php -d memory_limit=512M \
            "/var/www/leggo/$DIR/app/inc/lib/vendor/bin/phpunit" \
            -c "/var/www/leggo/$DIR/phpunit.xml"; then
            echo -e "${GREEN}  PHPUnit OK${NC}"
        else
            echo -e "${RED}  PHPUnit FAILED — push blocked${NC}"
            PHPUNIT_FAILED=true
        fi
    fi
done

if [ "$PHPUNIT_FAILED" = true ]; then
    echo -e "\n${YELLOW}Corrija os testes antes de subir. Para investigar:${NC}"
    echo -e "${YELLOW}  docker exec $CONTAINER php /var/www/leggo/site/app/inc/lib/vendor/bin/phpunit -c /var/www/leggo/site/phpunit.xml${NC}"
    exit 1
fi

echo -e "${GREEN}Pre-push checks passed.${NC}"
